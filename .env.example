# Supabase — identique pour les deux processus bot (prod et test partagent le même projet)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# UUID de la ligne correspondante dans la table `environments`
# Pour le processus prod :
ENVIRONMENT_ID_PROD=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Pour le processus test :
ENVIRONMENT_ID_TEST=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ⚠️  DISCORD_BOT_TOKEN n'est PAS défini ici — il est lu depuis Supabase (environments.discord_bot_token)
